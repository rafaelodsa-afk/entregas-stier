# Copie este arquivo para ".env" e preencha com os valores reais.
# NUNCA envie o ".env" de verdade para o GitHub (ele já está no .gitignore).

# String de conexão do banco Postgres. Se usar Neon (neon.tech, tem plano
# gratuito) ou Vercel Postgres, eles te dão essa URL pronta ao criar o banco.
DATABASE_URL="postgresql://usuario:senha@host:5432/banco?sslmode=require"

# Texto aleatório e secreto usado para assinar as sessões de login.
# Gere um novo com: openssl rand -base64 32
JWT_SECRET="troque-por-um-texto-aleatorio-grande-e-secreto"
